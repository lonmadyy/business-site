{% extends "layouts/base.njk" %}
{% set faq = [
  { q: 'Сколько стоит разработка?', a: 'Простой старт — от 690 BYN. Точная стоимость зависит от логики, интеграций и сроков.' },
  { q: 'Сколько времени занимает проект?', a: 'Лендинг или простой бот — около недели. Комплексные решения обычно занимают от 3 недель.' },
  { q: 'Работаете ли вы по договору?', a: 'Да. Фиксируем этапы, сроки, сумму и гарантийные обязательства до старта.' },
  { q: 'Что если результат не понравится?', a: 'Сначала показываем концепт. Вы видите направление до оплаты и снижаете риск ошибки.' },
  { q: 'Можете интегрировать с нашей CRM?', a: 'Да. Работаем с amoCRM, Bitrix24, 1С, Google Sheets, REST API и webhooks.' },
  { q: 'Разрабатываете сайты с нуля?', a: 'Да. Делаем кастомную разработку, когда шаблон или конструктор ограничивает задачу.' },
  { q: 'Работаете ли с клиентами не из Минска?', a: 'Да. Работаем удалённо по Беларуси и за её пределами, если проект можно вести онлайн.' },
  { q: 'Как происходит оплата?', a: 'Принимаем оплату по карте РБ или на расчётный счёт ИП. Делим стоимость на этапы — без полной предоплаты.' }
] %}
{% block json_ld %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Сайты и боты для бизнеса",
      "url": "{{ site.domain }}/",
      "image": "{{ site.domain }}{{ site.defaultOgImage }}",
      "description": "Сайты, Telegram-боты, Mini Apps и AI-интеграции под ключ для бизнеса в Минске и Беларуси.",
      "email": {{ site.email | dump | safe }},
      "telephone": {{ site.phoneRaw | dump | safe }},
      "priceRange": "BYN 690 - BYN 3490",
      "areaServed": [
        {"@type": "Country", "name": "Belarus"},
        {"@type": "City", "name": "Minsk"}
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Минск",
        "addressCountry": "BY"
      },
      "sameAs": [{{ site.telegram | dump | safe }}],
      "makesOffer": [
{%- for slug, s in services %}
{%- set priceNumeric = s.pricing.plans[0].price | replace('от ', '') | replace(' ', '') | replace('BYN', '') %}
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": {{ s.breadcrumbName | dump | safe }},
            "url": "{{ site.domain }}{{ s.permalink }}"
          },
          "priceSpecification": {
            "@type": "PriceSpecification",
            "price": {{ priceNumeric }},
            "priceCurrency": "BYN"
          }
        }{% if not loop.last %},{% endif %}
{%- endfor %}
      ]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
{%- for item in faq %}
        {
          "@type": "Question",
          "name": {{ item.q | dump | safe }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ item.a | dump | safe }}
          }
        }{% if not loop.last %},{% endif %}
{%- endfor %}
      ]
    }
    </script>
{% endblock %}
{% block body %}
    <main id="top">
{% set hero = {
  terminalPath: './launch',
  monoLabel: '[ Минск · Беларусь · 2026 ]',
  promptUser: 'dev@studio',
  promptDir: '~/digital-products',
  promptCommand: '$ run growth-system',
  h1Lines: ['Делаем цифровые', 'продукты которые'],
  morphPhrases: ['приносят клиентов', 'работают 24/7', 'продают'],
  sideBlurb: 'Сайты. Telegram-боты. AI-интеграции. Под ключ для бизнеса в Беларуси.',
  secondaryCta: { text: 'Смотреть цены', href: '#pricing' }
} %}
{% include "partials/hero-terminal.njk" %}

      <section class="proof section-reveal">
