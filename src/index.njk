{% include "partials/integrations.njk" %}

{% include "partials/timeline.njk" %}

      <section class="pricing section-reveal" id="pricing">
        <div class="container">
          <div class="section-heading section-heading--row pricing__heading">
            <div>
              <p class="mono-label">[ 04 ]</p>
              <h2>Цены без сюрпризов</h2>
