    {# Yandex.Metrika counter #}
    <script type="text/javascript">
       (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
       m[i].l=1*new Date();
       for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
       k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
       (window, document, "script", "https://mc.yandex.ru/metrika/tag.js?id={{ site.analytics.ymCounter }}", "ym");

       ym({{ site.analytics.ymCounter }}, "init", {
         ssr: true,
         webvisor: true,
         clickmap: true,
         ecommerce: "dataLayer",
         accurateTrackBounce: true,
         trackLinks: true
       });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/{{ site.analytics.ymCounter }}" style="position:absolute; left:-9999px;" alt="" /></div></noscript>

    {# Google Analytics 4 (gtag.js) #}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.ga4Id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "{{ site.analytics.ga4Id }}", {
        send_page_view: true,
        anonymize_ip: true
      });
    </script>

    {# Custom event tracking — выстреливает в обе системы одновременно #}
    <script>
      (function () {
        var YM_ID = {{ site.analytics.ymCounter }};

        function track(goal, params) {
          try { if (window.ym) window.ym(YM_ID, "reachGoal", goal, params || {}); } catch (e) {}
          try { if (window.gtag) window.gtag("event", goal, params || {}); } catch (e) {}
        }

        document.addEventListener("click", function (e) {
          var link = e.target.closest && e.target.closest("a[href]");
          if (link) {
            var href = link.getAttribute("href") || "";
            if (href.indexOf("https://t.me/") === 0) {
              track("telegram_click", { destination: href });
            } else if (href.indexOf("mailto:") === 0) {
              track("email_click");
            } else if (href.indexOf("tel:") === 0) {
              track("phone_click");
            }

            if (link.classList.contains("header-cta") && href === "/contacts/") {
              track("cta_contacts_click", { location: "header" });
            } else if (
              link.classList.contains("btn--primary") &&
              href === "/contacts/" &&
              link.closest(".hero__actions")
            ) {
              track("cta_contacts_click", { location: "hero" });
            }
          }

          var row = e.target.closest && e.target.closest(".service-row");
          if (row) {
            var name = (row.querySelector("strong") || {}).textContent || "unknown";
            track("service_click", { service: name.trim() });
          }
        }, { passive: true });
      })();
    </script>
