{% set anchorBase = '' if page.url == '/' else '/' %}
    <header class="site-header" data-header>
      <a class="brand" href="{{ '#top' if page.url == '/' else '/' }}" aria-label="На главную"></a>

      <nav class="desktop-nav" aria-label="Основная навигация">
        <a href="{{ anchorBase }}#services">Услуги</a>
        <a href="{{ anchorBase }}#process">Процесс</a>
        <a href="/contacts/"{% if page.url == '/contacts/' %} aria-current="page"{% endif %}>Контакты</a>
      </nav>

      {% if page.url == '/contacts/' %}
      <a class="btn btn--primary header-cta" href="/">На главную</a>
      {% else %}
      <a class="btn btn--primary header-cta" href="/contacts/">Связаться с нами</a>
      {% endif %}
      <button
        class="menu-toggle"
        type="button"
        aria-label="Открыть меню"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <span></span>
        <span></span>
      </button>
    </header>
